{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "ConnectionString": "mongodb://root:root@localhost:27017/?authSource=admin&directConnection=true&replicaSet=rs0",
    "Name": "celeste_inventory_dev"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "SchemaRegistryUrl": "http://localhost:8085"
  },
  "Authentication": {
    "Authority": "http://localhost:8080/realms/celeste",
    "Audience": "celeste.inventory",
    "RequireHttpsMetadata": false,
    "NameClaimType": "preferred_username",
    "UserIdClaimType": "sub"
  }
}
